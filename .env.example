# Copy this file to .env and fill in your key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gemini via LiteLLM proxy (free real LLM calls) — see LITELLM_GEMINI_SETUP.md
#
# MODE A · AUTO-FALLBACK (recommended): use Anthropic normally, and only when a
# run hits "credit balance too low" auto-retry via the local proxy. Keep your
# REAL sk-ant-... key above, add ONE provider key below, and DO NOT set
# ANTHROPIC_BASE_URL (that would force every run through the proxy).
#   then run:  ./run_proxy.sh
#
# Provider keys. DeepSeek and Anthropic are called DIRECTLY (no proxy); Groq and
# the Gemini auto-fallback go through the local LiteLLM proxy (./run_proxy.sh):
#   Free dropdown:  Groq        (proxy)
#   Paid dropdown:  DeepSeek    (direct — see below), Anthropic (direct, key above)
# GROQ_API_KEY=gsk_your-groq-key            # free at https://console.groq.com/keys
# GEMINI_API_KEY=AIza-your-gemini-key       # only old AIza format works (not AQ.)
#
# --- DeepSeek (direct, no proxy) ----------------------------------------------
# Selecting "DeepSeek API" in the UI calls https://api.deepseek.com/anthropic
# directly via DeepSeek's Anthropic-compatible API. Just set your key:
# DEEPSEEK_API_KEY=sk-your-deepseek-key     # paid at https://platform.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro            # optional; or deepseek-v4-flash (cheaper)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic   # optional override
#
# MODE B · ALWAYS GEMINI: route every run through the proxy (no Anthropic key
# needed). Set all four; ANTHROPIC_API_KEY must equal LITELLM_MASTER_KEY.
# GEMINI_API_KEY=AIza-your-gemini-key
# LITELLM_MASTER_KEY=sk-local-test
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=sk-local-test

# Research focus sources (optional) — which sites the research agents prioritise.
# Edit research_sources.txt instead for a readable list; or override here
# (comma-separated). Leave unset to use research_sources.txt / built-in defaults.
# RESEARCH_SOURCES=Amazon, Google Trends, Statista, Reddit, TikTok

# Email (SMTP) — optional; enables signup verification emails.
# For Office 365 with MFA, SMTP_PASSWORD must be an App Password.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_FROM=you@yourdomain.com
SMTP_PASSWORD=
APP_BASE_URL=http://127.0.0.1:8000
